rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ════════════════════════════════════════════════════════════════
    //  HELPER FUNCTIONS
    // ════════════════════════════════════════════════════════════════

    function getUserRole() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : '';
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    function hasRole(roles) {
      return isAuthenticated() && getUserRole() in roles;
    }


    // ════════════════════════════════════════════════════════════════
    //  CATEGORY 1 — USER MANAGEMENT
    // ════════════════════════════════════════════════════════════════

    match /users/{userId} {
      allow read: if isAuthenticated() &&
                     (request.auth.uid == userId ||
                      hasRole(['MIS', 'HCSD']));
      // Users may update only their own profile photo
      allow update: if request.auth.uid == userId &&
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['photoURL']);
      allow create, delete: if false;
    }


    // ════════════════════════════════════════════════════════════════
    //  CATEGORY 2 — PROJECT DATA
    // ════════════════════════════════════════════════════════════════

    match /projects/{projectId} {
      allow read: if hasRole(['MIS', 'HCSD', 'CPDO']) ||
                     (hasRole(['PROJ_ENG']) && resource.data.projectEngineer == request.auth.uid);
      allow create, update, delete: if false;

      // Milestones live as a subcollection under each project
      // PROJ_ENG can update (add geotagged proofs) — no create/delete from client
      match /milestones/{milestoneId} {
        allow read:   if hasRole(['MIS', 'HCSD', 'CPDO']) ||
                         (hasRole(['PROJ_ENG']) && get(/databases/$(database)/documents/projects/$(projectId)).data.projectEngineer == request.auth.uid);
        allow update: if hasRole(['PROJ_ENG']) &&
                         get(/databases/$(database)/documents/projects/$(projectId)).data.projectEngineer == request.auth.uid;
        allow create, delete: if false;
      }
    }


    // ════════════════════════════════════════════════════════════════
    //  CATEGORY 3 — AUDIT TRAILS
    //  Hierarchical: auditTrails/{scope}/entries/{logId}
    // ════════════════════════════════════════════════════════════════

    // MIS-scope: account provisioning, OTP, password changes
    match /auditTrails/mis/entries/{logId} {
      allow read:  if hasRole(['MIS']);
      allow write: if false;
    }

    // HCSD-scope: project created, PROJ_ENG accounts, profile updates
    match /auditTrails/hcsd/entries/{logId} {
      allow read:  if hasRole(['HCSD']);
      allow write: if false;
    }

    // Mobile-scope: PROJ_ENG field activity (logins, proof uploads)
    // MIS + HCSD can read for monitoring; PROJ_ENG appends their own logs
    match /auditTrails/mobile/entries/{logId} {
      allow read:   if hasRole(['MIS', 'HCSD', 'PROJ_ENG']);
      allow create: if hasRole(['PROJ_ENG']);
      allow update, delete: if false;
    }


    // ════════════════════════════════════════════════════════════════
    //  CATEGORY 4 — NOTIFICATIONS
    // ════════════════════════════════════════════════════════════════

    match /notifications/{notifId} {
      allow read:   if hasRole(['MIS', 'HCSD', 'CPDO', 'PROJ_ENG']);
      allow update: if hasRole(['MIS', 'HCSD', 'CPDO', 'PROJ_ENG']);
      allow create, delete: if false;
    }


    // ════════════════════════════════════════════════════════════════
    //  CATEGORY 5 — AUTHENTICATION / OTP
    // ════════════════════════════════════════════════════════════════

    match /otpCodes/{uid} {
      allow read, write: if false;
    }

    // Web app password reset (Firebase Auth link flow)
    match /passwordResets/{docId} {
      allow read, write: if false;
    }

    // Mobile app password reset (custom OTP flow)
    match /passwordResetOtps/{docId} {
      allow read, write: if false;
    }

    match /passwordResetCooldowns/{docId} {
      allow read, write: if false;
    }


    // ════════════════════════════════════════════════════════════════
    //  CATEGORY 6 — PUBLIC DATA
    // ════════════════════════════════════════════════════════════════

    match /stats/{docId} {
      allow read:  if docId == 'public';
      allow write: if false;
    }


    // ════════════════════════════════════════════════════════════════
    //  DEFAULT — Deny everything not explicitly matched above
    // ════════════════════════════════════════════════════════════════

    match /{document=**} {
      allow read, write: if false;
    }

  }
}
