rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ════════════════════════════════════════════════════════════════
    //  HELPER FUNCTIONS
    // ════════════════════════════════════════════════════════════════

    // Returns the calling user's role from the users collection.
    // Returns '' if the user document does not exist.
    function getUserRole() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : '';
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    // Returns true if the caller has one of the specified roles.
    function hasRole(roles) {
      return isAuthenticated() && getUserRole() in roles;
    }


    // ════════════════════════════════════════════════════════════════
    //  CATEGORY 1 — USER MANAGEMENT
    // ════════════════════════════════════════════════════════════════

    // users/{uid}
    //   Read:  Own document (any authenticated user) or MIS/DEPW (all docs)
    //   Write: BLOCKED — Cloud Functions (Admin SDK) only

    match /users/{userId} {
      allow read: if isAuthenticated() &&
                     (request.auth.uid == userId ||
                      hasRole(['MIS', 'DEPW']));
      allow write: if false;
    }


    // ════════════════════════════════════════════════════════════════
    //  CATEGORY 2 — PROJECT DATA
    // ════════════════════════════════════════════════════════════════

    // projects/{projectId}
    //   Read:  All authenticated roles (dashboards, registries, approvals)
    //   Write: BLOCKED — createProject Cloud Function via Admin SDK

    match /projects/{projectId} {
      allow read: if hasRole(['MIS', 'MAYOR', 'DEPW', 'CPDO', 'PROJ_ENG']);
      allow create, update, delete: if false;
    }

    // milestones/{milestoneId}
    //   Read:   All authenticated roles
    //   Update: PROJ_ENG only — for submitting proof images and progress updates
    //           (create/delete still handled by Cloud Functions / Admin SDK)

    match /milestones/{milestoneId} {
      allow read:   if hasRole(['MIS', 'MAYOR', 'DEPW', 'CPDO', 'PROJ_ENG']);
      allow update: if hasRole(['PROJ_ENG']);
      allow create, delete: if false;
    }


    // ════════════════════════════════════════════════════════════════
    //  CATEGORY 3 — AUDIT TRAILS
    // ════════════════════════════════════════════════════════════════

    // systemAuditTrails/{logId}  →  MIS SCOPE ONLY
    match /systemAuditTrails/{logId} {
      allow read:  if hasRole(['MIS']);
      allow write: if false;
    }

    // depwAuditTrails/{logId}  →  DEPW SCOPE ONLY
    match /depwAuditTrails/{logId} {
      allow read:  if hasRole(['DEPW']);
      allow write: if false;
    }

    // audit_logs/{logId}  →  MOBILE APP ACTIVITY LOG
    //   PROJ_ENG writes their own actions from the mobile app
    //   (e.g., logins, proof uploads, progress updates)
    //   DEPW and MIS can read to monitor PROJ_ENG field activity
    //   Append-only: no updates or deletes allowed

    match /audit_logs/{logId} {
      allow read:   if hasRole(['MIS', 'DEPW', 'PROJ_ENG']);
      allow create: if hasRole(['PROJ_ENG']);
      allow update, delete: if false;
    }


    // ════════════════════════════════════════════════════════════════
    //  CATEGORY 4 — NOTIFICATIONS (MOBILE APP)
    // ════════════════════════════════════════════════════════════════

    // notification/{notifId}
    //   All authenticated roles can read their notifications
    //   PROJ_ENG can update (mark as read) — no create/delete from client
    //   Creating notifications is done server-side (Cloud Functions / Admin SDK)

    match /notification/{notifId} {
      allow read:   if hasRole(['MIS', 'MAYOR', 'DEPW', 'CPDO', 'PROJ_ENG']);
      allow update: if hasRole(['MIS', 'MAYOR', 'DEPW', 'CPDO', 'PROJ_ENG']);
      allow create, delete: if false;
    }


    // ════════════════════════════════════════════════════════════════
    //  CATEGORY 5 — AUTHENTICATION / OTP
    // ════════════════════════════════════════════════════════════════

    match /otpCodes/{uid} {
      allow read, write: if false;
    }

    match /passwordResetCooldowns/{docId} {
      allow read, write: if false;
    }


    // ════════════════════════════════════════════════════════════════
    //  CATEGORY 6 — PUBLIC DATA
    // ════════════════════════════════════════════════════════════════

    match /stats/{docId} {
      allow read:  if docId == 'public';
      allow write: if false;
    }


    // ════════════════════════════════════════════════════════════════
    //  DEFAULT — Deny everything not explicitly matched above
    // ════════════════════════════════════════════════════════════════

    match /{document=**} {
      allow read, write: if false;
    }

  }
}
